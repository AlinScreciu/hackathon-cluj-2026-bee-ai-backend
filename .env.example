# LLM provider: openai | gemini | none (default)
LLM_PROVIDER=none

# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Required when LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Weather
WEATHER_PROVIDER=open-meteo
WEATHER_CACHE_S=600

# Logging
LOG_LEVEL=INFO

# Server
PORT=8000
